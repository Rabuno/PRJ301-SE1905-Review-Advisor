<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">

    <servlet>
        <servlet-name>MainController</servlet-name>
        <servlet-class>adapters.controllers.MainController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>adapters.controllers.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>adapters.controllers.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>adapters.controllers.LogoutController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ReviewServlet</servlet-name>
        <servlet-class>adapters.controllers.ReviewServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ModeratorServlet</servlet-name>
        <servlet-class>adapters.controllers.ModeratorServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MerchantServlet</servlet-name>
        <servlet-class>adapters.controllers.MerchantServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RolePermissionServlet</servlet-name>
        <servlet-class>adapters.controllers.RolePermissionServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserRoleServlet</servlet-name>
        <servlet-class>adapters.controllers.UserRoleServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProductModerationServlet</servlet-name>
        <servlet-class>adapters.controllers.ProductModerationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>MainController</servlet-name>
        <url-pattern>/MainController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/LogoutController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ReviewServlet</servlet-name>
        <url-pattern>/ReviewServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ModeratorServlet</servlet-name>
        <url-pattern>/ModeratorServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MerchantServlet</servlet-name>
        <url-pattern>/MerchantServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RolePermissionServlet</servlet-name>
        <url-pattern>/Admin/RolePermissions</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UserRoleServlet</servlet-name>
        <url-pattern>/Admin/UserRoles</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProductModerationServlet</servlet-name>
        <url-pattern>/ModeratorProducts</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>infrastructure.security.RoleFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <listener>
        <listener-class>infrastructure.persistence.DatabaseInitListener</listener-class>
    </listener>
    <listener>
        <listener-class>infrastructure.config.AppConfigListener</listener-class>
    </listener>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

</web-app>
